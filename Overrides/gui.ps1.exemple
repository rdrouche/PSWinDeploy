#     $idx = Show-PSWDList -Title 'Choisir le systeme' -Items ($wims | ForEach-Object { $_.Name })
#     return $wims[$idx].FullName
# }

Write-PSWDNotify "Surcharge GUI (exemple) chargee." 'OK'
