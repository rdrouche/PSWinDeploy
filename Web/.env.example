# --------------#
# -- REQUIRED --#
# --------------#

# URL de l'API PowerShell (Pode), joignable depuis le conteneur.
#URL_API_PSWINDEPLOY=http://psdeploy-server:8080

# Token de l'API (doit etre IDENTIQUE a 'apiToken' du PSWinDeploy.psd1).
# Injecte cote serveur par le BFF, jamais expose au navigateur.
#TOKEN_API_PSWINDEPLOY=xxxxxxx

# Mot de passe admin : DEUX options.
# Option recommandee -- HASH (le mot de passe en clair n'apparait nulle part) :
#   genere-le : docker run --rm <image> node hash-password.js "TonMdp"
#   (ou : node server/hash-password.js "TonMdp")
# Il est possible d avoir le hash par url suivante : http://pswindeploy-web:8088/hash
# Si le hash est colle directement dans le compose.yml il faut double le $ (scrypt$xxx -> scrypt$$xxx)
#PASSWORD_ADMIN_HASH=scrypt$REMPLACE_PAR_TON_HASH

# Option simple (deconseillee en prod) -- mot de passe en clair :
# PASSWORD_ADMIN: "REMPLACE_PAR_TON_MOT_DE_PASSE"
# Identifiant admin (optionnel, defaut 'admin').

# --------------#
# -- OPTIONAL --#
# --------------#
# Tag de l'image
#TAG_PSWD_WEB=
# Identifiant admin de l'interface web.
#ADMIN_USER="admin"
# Duree d'une session en heures (optionnel).
#SESSION_TTL_HOURS=12